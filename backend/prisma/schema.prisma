// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SUPER_ADMIN
}

enum SubscriptionPlan {
  FREE_TRIAL
  PRO
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

// ========================================
// USER & AUTH
// ========================================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          UserRole  @default(USER)
  isSuspended   Boolean   @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Subscription
  stripeCustomerId   String?   @unique
  trialEndsAt        DateTime?
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  subscriptionPlan   SubscriptionPlan   @default(FREE_TRIAL)
  subscriptionEndsAt DateTime?

  // Relations (Multi-Tenant ready)
  customers          Customer[]
  projects           Project[]
  invoices           Invoice[]
  payments           Payment[]
  onboardingProfile  OnboardingProfile?
  onboardingEvents   OnboardingEvent[]
  timeEntries        TimeEntry[]
  appointments       Appointment[]
  quotes             Quote[]
  expenses           Expense[]
  bankAccounts       BankAccount[]

  @@map("users")
}

// ========================================
// CUSTOMERS
// ========================================
model Customer {
  id                  String    @id @default(cuid())
  ownerId             String

  name                String
  company             String?
  email               String
  defaultPaymentTerms Int       @default(30)  // Tage
  notes               String?   @db.Text

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  owner               User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  projects            Project[]
  invoices            Invoice[]
  appointments        Appointment[]
  quotes              Quote[]

  // Indexes für Performance & Security
  @@index([ownerId])
  @@unique([email, ownerId], name: "email_ownerId")
  @@map("customers")
}

// ========================================
// BANK ACCOUNTS / PAYMENT METHODS
// ========================================
model BankAccount {
  id              String    @id @default(cuid())
  ownerId         String

  name            String    // z.B. "Geschäftskonto Sparkasse"
  bankName        String?   // z.B. "Sparkasse Berlin"
  iban            String?
  bic             String?
  accountHolder   String?   // z.B. "Max Mustermann"
  
  // Für PayPal oder andere Methoden
  isPaypal        Boolean   @default(false)
  paypalEmail     String?

  isDefault       Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  owner           User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  invoices        Invoice[]

  @@index([ownerId])
  @@map("bank_accounts")
}

// ========================================
// INVOICES
// ========================================
enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum RecurringInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

model Invoice {
  id              String        @id @default(cuid())
  ownerId         String
  customerId      String
  projectId       String?       // Optional - invoices can exist without project

  // Rechnungsdaten
  invoiceNumber   String?       // Zukunft: Auto-generated, rechtssicher
  amount          Decimal       @db.Decimal(10, 2)
  description     String        @db.Text

  // Statusberechnung
  status          InvoiceStatus @default(DRAFT)
  totalPaid       Decimal       @default(0) @db.Decimal(10, 2)  // Denormalisiert für Performance

  // Daten
  issueDate       DateTime      @default(now())
  dueDate         DateTime

  // Public token for client portal
  publicToken     String?       @unique @default(cuid())

  // Dunning (Mahnwesen)
  dunningLevel    Int           @default(0)  // 0=none, 1=reminder, 2=1st notice, 3=2nd notice, 4=final
  lastDunningDate DateTime?

  // Recurring invoices
  isRecurring          Boolean           @default(false)
  recurringInterval    RecurringInterval?
  recurringStartDate   DateTime?
  recurringEndDate     DateTime?
  nextInvoiceDate      DateTime?
  parentInvoiceId      String?           // Link recurring child invoices to template

  // Payment Method Snapshot
  bankAccountId        String?           // Link to the bank account used
  
  // Snapshot data in case bank account is deleted/changed later
  paymentDetails       Json?             // Stores specific payment info (IBAN, etc.) at time of creation

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  owner           User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  bankAccount     BankAccount?  @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  payments        Payment[]
  timeEntries     TimeEntry[]

  // Indexes
  @@index([ownerId])
  @@index([customerId, ownerId])
  @@index([projectId, ownerId])
  @@index([status, ownerId])
  @@index([dueDate, status, ownerId])  // Für Overdue-Queries
  @@index([publicToken])
  @@index([nextInvoiceDate])           // Für Recurring-Queries
  @@map("invoices")
}

// ========================================
// PAYMENTS
// ========================================
model Payment {
  id          String    @id @default(cuid())
  ownerId     String
  invoiceId   String

  amount      Decimal   @db.Decimal(10, 2)
  paymentDate DateTime  @default(now())
  note        String?   @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([ownerId])
  @@index([invoiceId, ownerId])
  @@index([paymentDate, ownerId])  // Für Cashflow-Queries
  @@map("payments")
}

// ========================================
// QUOTES / ANGEBOTE
// ========================================
enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  CONVERTED
}

model Quote {
  id              String      @id @default(cuid())
  ownerId         String
  customerId      String
  projectId       String?

  quoteNumber     String?
  amount          Decimal     @db.Decimal(10, 2)
  description     String      @db.Text

  status          QuoteStatus @default(DRAFT)

  issueDate       DateTime    @default(now())
  validUntil      DateTime

  notes           String?     @db.Text

  // Konvertierung zu Rechnung
  convertedToInvoiceId String? @unique

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  owner           User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  project         Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Indexes
  @@index([ownerId])
  @@index([customerId, ownerId])
  @@index([status, ownerId])
  @@map("quotes")
}

// ========================================
// EXPENSES / AUSGABEN
// ========================================
enum ExpenseCategory {
  SOFTWARE
  HARDWARE
  TRAVEL
  MARKETING
  OFFICE
  TRAINING
  OTHER
}

model Expense {
  id          String          @id @default(cuid())
  ownerId     String

  amount      Decimal         @db.Decimal(10, 2)
  description String
  category    ExpenseCategory @default(OTHER)
  date        DateTime        @default(now())

  receiptUrl  String?
  notes       String?         @db.Text

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  owner       User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([ownerId])
  @@index([category, ownerId])
  @@index([date, ownerId])
  @@map("expenses")
}

// ========================================
// ONBOARDING
// ========================================
enum FreelancerVertical {
  DESIGNER
  DEVELOPER
  CONSULTANT
  MARKETING_CONTENT
  PHOTOGRAPHER_VIDEOGRAPHER
  OTHER
}

enum CurrentWorkflow {
  EXCEL_SHEETS
  WORD_DOCUMENTS
  OTHER_SOFTWARE
  UNORGANIZED
}

enum BusinessStage {
  JUST_STARTED      // 0-6 Monate
  GROWING          // 6-24 Monate
  ESTABLISHED      // 2+ Jahre
  SIDE_BUSINESS
}

enum AcquisitionChannel {
  LINKEDIN
  REDDIT
  FACEBOOK_GROUP
  REFERRAL
  GOOGLE_SEARCH
  OTHER
}

model OnboardingProfile {
  id        String   @id @default(cuid())
  userId    String   @unique

  // Step 1: Branchensegmentierung
  vertical  FreelancerVertical?

  // Step 2: Aktueller Workflow / Pain Point
  currentWorkflow  CurrentWorkflow?

  // Step 3: Business Stage
  businessStage    BusinessStage?

  // Step 4: Marketing Attribution
  acquisitionChannel       AcquisitionChannel?
  acquisitionChannelOther  String?  // Wenn "OTHER" gewählt

  // Progress Tracking
  onboardingCompleted   Boolean   @default(false)
  currentStep          Int       @default(1)  // 1-5
  completedAt          DateTime?

  // Extensibility: JSON für zusätzliche Daten
  additionalData       Json?     // Für zukünftige Fragen ohne Schema-Migration

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([vertical])  // Für Segmentierungs-Queries
  @@index([acquisitionChannel])  // Für Attribution-Analytics
  @@index([onboardingCompleted])
  @@map("onboarding_profiles")
}

// ========================================
// ONBOARDING EVENTS (Analytics)
// ========================================
enum OnboardingEventType {
  STEP_VIEWED
  STEP_COMPLETED
  STEP_SKIPPED
  ONBOARDING_STARTED
  ONBOARDING_COMPLETED
  ONBOARDING_ABANDONED
}

model OnboardingEvent {
  id          String              @id @default(cuid())
  userId      String

  eventType   OnboardingEventType
  stepNumber  Int?                // Welcher Schritt (1-5)
  metadata    Json?               // Zusätzliche Event-Daten

  createdAt   DateTime            @default(now())

  // Relations
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType])
  @@index([eventType, createdAt])  // Für Analytics-Queries
  @@map("onboarding_events")
}

// ========================================
// PROJECTS
// ========================================
enum ProjectStatus {
  PLANNING      // Planungsphase
  ACTIVE        // In Bearbeitung
  ON_HOLD       // Pausiert
  COMPLETED     // Abgeschlossen
  CANCELLED     // Abgebrochen
}

model Project {
  id              String        @id @default(cuid())
  ownerId         String
  customerId      String?       // Optional - Projekte können ohne Kunde existieren

  name            String
  description     String?       @db.Text
  status          ProjectStatus @default(PLANNING)
  budget          Decimal?      @db.Decimal(10, 2)

  startDate       DateTime?
  endDate         DateTime?
  notes           String?       @db.Text

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  owner           User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoices        Invoice[]
  timeEntries     TimeEntry[]
  appointments    Appointment[]
  quotes          Quote[]

  // Indexes
  @@index([ownerId])
  @@index([customerId, ownerId])
  @@index([status, ownerId])
  @@index([startDate, ownerId])
  @@map("projects")
}

// ========================================
// APPOINTMENTS
// ========================================
model Appointment {
  id              String    @id @default(cuid())
  ownerId         String
  customerId      String?   // Optional - appointments can exist without customer
  projectId       String?   // Optional - appointments can exist without project

  title           String
  description     String?   @db.Text
  startTime       DateTime
  endTime         DateTime

  // Contact Person Details
  contactName     String?
  contactEmail    String?
  contactPhone    String?

  // Meeting details
  meetingLink     String?   // URL for Teams, Zoom, etc.
  meetingId       String?   // ID for the meeting

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  owner           User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Indexes
  @@index([ownerId])
  @@index([customerId, ownerId])
  @@index([projectId, ownerId])
  @@index([startTime, ownerId])
  @@map("appointments")
}

// ========================================
// TIME TRACKING
// ========================================
model TimeEntry {
  id              String    @id @default(cuid())
  ownerId         String
  projectId       String?
  invoiceId       String?   // Optional: linked to an invoice for billing

  description     String?   @db.Text
  duration        Int       @default(0) // In Sekunden
  pauseDuration   Int       @default(0) // In Sekunden
  startTime       DateTime  @default(now())
  endTime         DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  owner           User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  // Indexes
  @@index([ownerId])
  @@index([projectId, ownerId])
  @@index([startTime, ownerId])
  @@index([invoiceId])
  @@map("time_entries")
}
