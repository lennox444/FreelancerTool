# ===================================
# BACKEND ENVIRONMENT VARIABLES
# ===================================

# Database Connection
DATABASE_URL="postgresql://user:password@localhost:5432/freelancer_db"

# JWT Secrets (CHANGE IN PRODUCTION!)
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-minimum-32-characters"

# Server Configuration
PORT=3001
NODE_ENV=development

# ===================================
# FRONTEND ENVIRONMENT VARIABLES
# ===================================

# API URL (Backend URL)
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# ===================================
# DOCKER COMPOSE VARIABLES
# ===================================

# Database (for docker-compose)
POSTGRES_DB=freelancer_dev
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev

# ===================================
# PRODUCTION NOTES
# ===================================
#
# For production deployment:
# 1. Generate secure JWT secrets (minimum 32 characters)
# 2. Use a strong database password
# 3. Set NODE_ENV=production
# 4. Configure NEXT_PUBLIC_API_URL to your production API URL
# 5. Never commit actual secrets to git
#
